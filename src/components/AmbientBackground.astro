---
/**
 * AmbientBackground - Global ambient floating elements
 * Renders floating particles, drifting shapes, and subtle grid pulses
 * so there's always something moving on every page.
 */
---

<div class="ambient-bg" aria-hidden="true">
  <!-- Floating particles layer -->
  <div class="ambient-particles">
    <div class="particle p1"></div>
    <div class="particle p2"></div>
    <div class="particle p3"></div>
    <div class="particle p4"></div>
    <div class="particle p5"></div>
    <div class="particle p6"></div>
    <div class="particle p7"></div>
    <div class="particle p8"></div>
  </div>

  <!-- Drifting gradient orbs -->
  <div class="ambient-orb orb-1"></div>
  <div class="ambient-orb orb-2"></div>
  <div class="ambient-orb orb-3"></div>

  <!-- Scanning line -->
  <div class="ambient-scanline"></div>
</div>

<style is:global>
  .ambient-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .ambient-bg {
      display: none;
    }
  }

  /* Floating particles */
  .ambient-particles {
    position: absolute;
    inset: 0;
  }

  .particle {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    opacity: 0;
    animation: particle-drift linear infinite;
  }

  .p1 {
    left: 10%;
    background: rgba(214, 72, 255, 0.5);
    animation-duration: 18s;
    animation-delay: 0s;
  }
  .p2 {
    left: 25%;
    background: rgba(6, 182, 212, 0.4);
    animation-duration: 22s;
    animation-delay: -4s;
  }
  .p3 {
    left: 40%;
    background: rgba(214, 72, 255, 0.3);
    animation-duration: 20s;
    animation-delay: -8s;
  }
  .p4 {
    left: 55%;
    background: rgba(99, 102, 241, 0.4);
    animation-duration: 24s;
    animation-delay: -2s;
  }
  .p5 {
    left: 70%;
    background: rgba(6, 182, 212, 0.3);
    animation-duration: 19s;
    animation-delay: -10s;
  }
  .p6 {
    left: 85%;
    background: rgba(214, 72, 255, 0.4);
    animation-duration: 21s;
    animation-delay: -6s;
  }
  .p7 {
    left: 35%;
    background: rgba(236, 72, 153, 0.3);
    animation-duration: 25s;
    animation-delay: -12s;
  }
  .p8 {
    left: 65%;
    background: rgba(99, 102, 241, 0.3);
    animation-duration: 17s;
    animation-delay: -14s;
  }

  @keyframes particle-drift {
    0% {
      transform: translateY(100vh) translateX(0px) scale(0);
      opacity: 0;
    }
    5% {
      opacity: 0.6;
      transform: translateY(90vh) translateX(10px) scale(1);
    }
    50% {
      opacity: 0.3;
      transform: translateY(40vh) translateX(-20px) scale(0.8);
    }
    95% {
      opacity: 0.5;
      transform: translateY(-5vh) translateX(15px) scale(0.6);
    }
    100% {
      transform: translateY(-10vh) translateX(0px) scale(0);
      opacity: 0;
    }
  }

  /* Gradient orbs - large soft blurs that drift slowly */
  .ambient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.04;
    animation: orb-drift ease-in-out infinite;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(214, 72, 255, 0.6), transparent 70%);
    top: 20%;
    left: -5%;
    animation-duration: 30s;
  }

  .orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.6), transparent 70%);
    top: 60%;
    right: -5%;
    animation-duration: 25s;
    animation-delay: -8s;
  }

  .orb-3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.5), transparent 70%);
    bottom: 10%;
    left: 30%;
    animation-duration: 35s;
    animation-delay: -15s;
  }

  @keyframes orb-drift {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(40px, -30px) scale(1.1);
    }
    50% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    75% {
      transform: translate(30px, 40px) scale(1.05);
    }
  }

  /* Scanning line - horizontal line that scrolls down slowly */
  .ambient-scanline {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(214, 72, 255, 0.15), rgba(6, 182, 212, 0.15), transparent);
    animation: scanline-move 8s linear infinite;
    opacity: 0.6;
  }

  @keyframes scanline-move {
    0% {
      top: -2px;
    }
    100% {
      top: 100%;
    }
  }

  /* Ensure main content is above ambient background */
  body > header,
  body > main,
  body > footer {
    position: relative;
    z-index: 1;
  }
</style>
