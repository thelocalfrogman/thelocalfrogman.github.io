---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="404 - Page Not Found">
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden section-themed">
    <!-- Grid pattern background -->
    <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative z-10 px-4 text-center">
      <!-- Glitch 404 text -->
      <h1 class="glitch-text relative inline-block text-9xl font-black text-white" data-text="404">
        404
      </h1>

      <p class="mt-6 text-2xl font-semibold text-gray-400">
        Page not found
      </p>

      <p class="mt-3 text-lg" style="color: var(--theme-text-secondary, #9ca3af);">
        Looks like this page got hacked...
      </p>

      <a
        href="/"
        class="group mt-10 inline-flex items-center gap-2 rounded border border-green-500/50 bg-green-500/10 px-6 py-3 font-mono text-sm text-green-400 transition-all hover:border-green-400 hover:bg-green-500/20 hover:text-green-300"
      >
        <span class="opacity-70">$</span> Back to Safety
        <Icon aria-hidden="true" name="lucide:shield" class="h-4 w-4" />
      </a>
    </div>
  </section>
</DefaultLayout>

<style>
  .glitch-text {
    animation: glitch-skew 4s infinite linear alternate-reverse;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }

  .glitch-text::before {
    color: #0ff;
    animation: glitch 3s infinite linear alternate-reverse;
    z-index: -1;
  }

  .glitch-text::after {
    color: #f0f;
    animation: glitch 2s infinite linear alternate-reverse reverse;
    z-index: -1;
  }

  @keyframes glitch {
    0%, 100% {
      clip-path: inset(0 0 80% 0);
      transform: translate(0);
    }
    20% {
      clip-path: inset(20% 0 60% 0);
      transform: translate(-2px, 2px);
    }
    40% {
      clip-path: inset(40% 0 40% 0);
      transform: translate(2px, -2px);
    }
    60% {
      clip-path: inset(60% 0 20% 0);
      transform: translate(-1px, 1px);
    }
    80% {
      clip-path: inset(80% 0 0% 0);
      transform: translate(1px, -1px);
    }
  }

  @keyframes glitch-skew {
    0%, 95%, 100% {
      transform: skew(0deg);
    }
    96% {
      transform: skew(-0.5deg);
    }
    98% {
      transform: skew(0.5deg);
    }
  }
</style>
