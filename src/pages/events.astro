---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { BackgroundBeams } from '@components/ui/background-beams'
import { EventTagFilter } from '@components/ui/event-tag-filter'
import { getCollection } from 'astro:content'

// Fetch all events from the collection
const allEvents = await getCollection('events')

// Extract unique tags
const allTags = [...new Set(allEvents.flatMap(e => e.data.tags || []))]

// Serialize events for the React component
const serializedEvents = allEvents.map((event) => ({
  title: event.data.title,
  description: event.data.description,
  eventDate: event.data.eventDate.toISOString(),
  endDate: event.data.endDate?.toISOString(),
  location: event.data.location,
  tags: event.data.tags,
  registrationUrl: event.data.registrationUrl,
  slug: event.data.slug,
}))
---

<DefaultLayout title="Events">
  <!-- Hero Section with Background Beams -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden section-themed">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-900/20 via-transparent to-transparent"></div>
    <BackgroundBeams className="opacity-40" client:load />
    <div class="absolute inset-0 bg-grid-pattern"></div>

    <div class="relative z-10 container mx-auto px-4 py-20 text-center">
      <h1 class="text-5xl md:text-7xl font-bold mb-6">
        <span class="bg-gradient-to-r from-orange-400 to-red-500 bg-clip-text text-transparent">Events</span>
      </h1>
      <p class="text-xl theme-text-secondary max-w-2xl mx-auto mb-8">
        Join us for workshops, competitions, networking events, and more. There's always something happening at DUCA!
      </p>
      <a
        href="https://humanitix.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-orange-600 text-white font-semibold hover:bg-orange-700 transition-colors"
      >
        Register on Humanitix
      </a>
    </div>
  </section>

  <!-- Events with Tag Filtering -->
  <section class="py-24 section-themed">
    <div class="container mx-auto px-4">
      <EventTagFilter events={serializedEvents} tags={allTags} client:load />
    </div>
  </section>

  <!-- CTA - Glow Ring Discord -->
  <section class="py-24 section-themed">
    <div class="container mx-auto px-4 text-center">
      <div class="max-w-2xl mx-auto p-12 rounded-2xl border-2 border-purple-500/30 animate-pulse-glow bg-gradient-to-br from-purple-900/20 to-black">
        <h2 class="text-3xl md:text-4xl font-bold theme-text mb-6">
          Want to stay updated?
        </h2>
        <p class="theme-text-secondary max-w-2xl mx-auto mb-8">
          Join our Discord to get instant notifications about upcoming events and activities.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://discord.gg/duca"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-purple-600 text-white font-semibold hover:bg-purple-700 transition-colors"
          >
            Join Discord
          </a>
          <a
            href="/calendar"
            class="inline-flex items-center justify-center px-6 py-3 rounded-full border-2 border-purple-500 theme-text font-semibold hover:bg-purple-500/10 transition-colors"
          >
            View Calendar
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

<style is:global>
  /* Easter egg: ACCESS GRANTED flash */
  .access-granted-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.9);
    pointer-events: none;
  }
  .access-granted-overlay span {
    font-family: monospace;
    font-size: 4rem;
    font-weight: bold;
    color: #33ff33;
    text-shadow: 0 0 30px rgba(51, 255, 51, 0.8);
    animation: ag-pulse 0.5s ease-in-out;
  }
  @keyframes ag-pulse {
    0%, 100% { opacity: 0; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  // Easter Egg: Type "sudo" → ACCESS GRANTED flash
  document.addEventListener('astro:page-load', () => {
    let buffer = '';
    document.addEventListener('keydown', (e) => {
      buffer += e.key.toLowerCase();
      if (buffer.length > 10) buffer = buffer.slice(-10);
      if (buffer.includes('sudo')) {
        buffer = '';
        const overlay = document.createElement('div');
        overlay.className = 'access-granted-overlay';
        overlay.innerHTML = '<span>ACCESS GRANTED</span>';
        document.body.appendChild(overlay);
        setTimeout(() => overlay.remove(), 2000);
      }
    });
  });
</script>
